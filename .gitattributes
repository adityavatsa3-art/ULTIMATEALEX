# Normalize line endings to LF on commit
* text=auto eol=lf

# Force binary files to stay binary
*.png binary
*.jpg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.otf binary
*.exe binary
*.dll binary

# PowerShell - Windows CRLF
*.ps1 text eol=crlf
*.psm1 text eol=crlf
*.psd1 text eol=crlf

# Lua
*.lua text eol=lf
