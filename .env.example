# ═══════════════════════════════════════════
#  OMNI-LLM-SUITE — Unified Configuration
# ═══════════════════════════════════════════

# ─── Gateway ──────────────────────────────
GATEWAY_PORT=8080
GATEWAY_HOST=127.0.0.1
GATEWAY_LOG_LEVEL=Information

# ─── Anthropic / Claude ──────────────────
ANTHROPIC_API_KEY=sk-ant-omni-gateway
ANTHROPIC_BASE_URL=http://localhost:4141

# ─── OpenRouter (Fallback) ───────────────
OPENROUTER_API_KEY=YOUR_KEY_HERE

# ─── Ollama (Local) ──────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_ENABLED=true

# ─── Rotato (Key Rotation) ───────────────
PORT=8990
ADMIN_PASSWORD=change-me-in-production
ROTATO_PORT=8990
ROTATO_ADMIN_PASSWORD=change-me-in-production
ROTATO_TELEGRAM_BOT_TOKEN=
ROTATO_TELEGRAM_ALLOWED_USERS=

# ─── Claude Cruise (429 Proxy) ───────────
CRUISE_PORT=4141
CRUISE_FALLBACK_PROVIDER=openrouter
CRUISE_MODEL_MAP={"claude-sonnet-4-20250514":"anthropic/claude-sonnet-4-20250514"}

# ─── Free LLM Proxy Mixture ─────────────
MOA_AGGREGATOR_PORT=8007
MOA_WORKER_COUNT=3
GEMINI_PROJECT_ID=

# ─── Redis (Rate Limiting) ───────────────
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# ─── TLS ──────────────────────────────────
TLS_MIN_VERSION=1.3
TLS_CERT_PATH=./certs/server.crt
TLS_KEY_PATH=./certs/server.key
